# =============================================================
# WhatPromo — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# =============================================================

# --- Provedor de IA (groq | claude | openai) ---
PROVEDOR_IA=groq
CHAVE_API_GROQ=gsk_xxx
CHAVE_API_ANTHROPIC=sk-ant-xxx
CHAVE_API_OPENAI=sk-xxx

# --- Banco de dados (MariaDB) ---
BD_HOST=banco_dados
BD_PORTA=3306
BD_NOME=whatpromo_db
BD_USUARIO=whatpromo_usuario
BD_SENHA=senha_forte_aqui
BD_SENHA_ROOT=senha_root_aqui

# --- Evolution API (WhatsApp) ---
EVOLUTION_URL=http://evolution_api:8080
EVOLUTION_CHAVE=chave_evolution_aqui
EVOLUTION_INSTANCIA=whatpromo

# --- Bot Telegram ---
CHAVE_BOT_TELEGRAM=token_do_botfather_aqui
ID_CHAT_ADMIN_TELEGRAM=seu_id_numerico_aqui

# --- Afiliados ---
TAG_AFILIADO_ML=whatpromo_ml
TAG_AFILIADO_SHOPEE=whatpromo_shopee

# --- Encurtador de URL (dub.co) ---
CHAVE_ENCURTADOR=dub_xxx
DOMINIO_ENCURTADOR=wtp.to

# --- Airflow ---
AIRFLOW_CHAVE_FERNET=gerar_com_python_fernet
AIRFLOW_USUARIO_ADMIN=admin
AIRFLOW_SENHA_ADMIN=senha_airflow_aqui

# --- Laravel (Fase 4) ---
APP_CHAVE=base64:gerar_com_php_artisan_key_generate
APP_AMBIENTE=production
APP_DEBUG=false
APP_URL=http://144.91.70.44

# --- E-mail (notificações) ---
EMAIL_ADMIN=email@exemplo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORTA=587
SMTP_USUARIO=email@exemplo.com
SMTP_SENHA=senha_de_app_gmail
